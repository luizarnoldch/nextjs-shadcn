generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FileState {
  PENDING
  UPLOADED
  DELETED
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model File {
  id         String         @id @default(uuid())
  name       String
  type       String
  size       Int
  state      FileState      @default(PENDING)
  visibility FileVisibility @default(PUBLIC)
  key        String?
  url        String?
  uploadedAt DateTime       @default(now())
  deletedAt  DateTime?

  @@map("file")
}

model Task {
  id        String    @id @default(uuid())
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("task")
}

enum TestEnum {
  OPTION_A
  OPTION_B
  OPTION_C
}

model FormTest {
  id            String   @id @default(uuid())
  textField     String
  numberField   Int
  decimalField  Decimal
  floatField    Float
  booleanField  Boolean
  dateField     DateTime
  longTextField String   @db.Text
  jsonField     Json
  enumField     TestEnum
  optionalField String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("form_test")
}