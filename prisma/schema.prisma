generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum FileState {
  PENDING
  UPLOADED
  DELETED
}

enum FileVisibility {
  PUBLIC
  PRIVATE
}

model File {
  id         String         @id @default(uuid())
  name       String
  type       String
  size       Int
  state      FileState      @default(PENDING)
  visibility FileVisibility @default(PUBLIC)
  key        String?
  url        String?
  uploadedAt DateTime       @default(now())
  deletedAt  DateTime?

  @@map("file")
}
